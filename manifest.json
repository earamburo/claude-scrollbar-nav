{
  "manifest_version": 3,
  "name": "Claude Chat Minimap Navigator",
  "version": "1.0.0",
  "description": "Visual scrollbar minimap with clickable flags for Claude conversations",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}